---
import PageHero from '~/components/widgets/PageHero.astro';
import PmCard from '~/components/ui/PmCard.astro';
import IconBadge from '~/components/ui/IconBadge.astro';
import { getLangFromUrl } from '~/utils/i18n';
import { teamPageCopy } from '~/utils/i18n-team-page';

const lang = getLangFromUrl(Astro.url);
const copy = lang === 'fr' ? teamPageCopy.fr : lang === 'ar' ? teamPageCopy.ar : teamPageCopy.en;
const pageHeroLang = lang === 'fr' ? 'fr' : lang === 'ar' ? 'ar' : 'en';
---

<PageHero
  lang={pageHeroLang}
  heroImage="/4.avif"
  eyebrow={copy.hero.eyebrow}
  heading={copy.hero.heading}
  headingAccent={copy.hero.headingAccent}
  subtext={copy.hero.subtext}
/>

<section class="pm-section pm-section--mesh pm-section--dots pm-section--sep">
  <div class="pm-container">
    <div class="mx-auto max-w-4xl">
      <div class="pm-card p-8 md:p-12">
        <div class="grid items-center gap-10 md:grid-cols-3 md:gap-12">
          <div class="md:col-span-1" data-pm-reveal data-pm-reveal-once>
            <div
              class="mx-auto max-w-[240px] overflow-hidden rounded-xl border border-[color:var(--pm-border)] shadow-lg md:mx-0"
            >
              <img
                src="/images/team/Dr_mohame_amria.png"
                alt={copy.profile.imageAlt}
                class="h-full min-h-[220px] w-full object-cover object-top"
                loading="lazy"
              />
            </div>
          </div>
          <div class="pm-reveal-from-right md:col-span-2" data-pm-reveal data-pm-reveal-once>
            <h3 class="pm-bracket-heading font-heading text-2xl font-bold text-[color:var(--pm-text-heading)] md:text-3xl">
              {copy.profile.name}
            </h3>
            <p class="mb-4 text-lg font-semibold text-[color:var(--pm-accent)]">{copy.profile.role}</p>
            <p class="mb-6 font-body text-[color:var(--pm-text-body)]">{copy.profile.bio}</p>
            <div class="mb-6 grid gap-4 md:grid-cols-2">
              <div
                class="rounded-2xl border border-[color:var(--pm-border)] bg-[color:var(--pm-surface-elevated)] p-6 shadow-lg"
              >
                <h4 class="font-heading mb-3 text-lg font-bold text-[color:var(--pm-text-heading)]">
                  {copy.profile.academicTitle}
                </h4>
                <ul class="space-y-1 font-body text-sm text-[color:var(--pm-text-body)]">
                  {copy.profile.academicBullets.map((b) => (
                    <li>• {b}</li>
                  ))}
                </ul>
              </div>
              <div
                class="rounded-2xl border border-[color:var(--pm-border)] bg-[color:var(--pm-surface-elevated)] p-6 shadow-lg"
              >
                <h4 class="font-heading mb-3 text-lg font-bold text-[color:var(--pm-text-heading)]">
                  {copy.profile.impactTitle}
                </h4>
                <ul class="space-y-1 font-body text-sm text-[color:var(--pm-text-body)]">
                  {copy.profile.impactBullets.map((b) => (
                    <li>• {b}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="pm-section pm-section--mesh pm-section--sep">
  <div class="pm-container">
    <header class="pm-section-header" data-pm-reveal data-pm-reveal-once>
      <h2 class="pm-section-title">
        {copy.expertiseIntro.heading}{' '}
        <span class="pm-gradient-text">{copy.expertiseIntro.headingAccent}</span>
      </h2>
      <p class="pm-section-sub">{copy.expertiseIntro.subtext}</p>
    </header>

    <div class="pm-grid">
      {
        copy.expertiseCards.map((item, i) => (
          <div data-pm-reveal data-pm-reveal-once>
            <PmCard
              icon={item.icon}
              iconColor={i % 2 === 0 ? 'gold' : 'sage'}
              title={item.title}
              description={item.description}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<section class="pm-section pm-section--mesh pm-section--sep">
  <div class="pm-container">
    <div class="pm-split">
      <div class="order-2 space-y-6 lg:order-1" data-pm-reveal data-pm-reveal-once>
        <p class="pm-eyebrow">{copy.collaborationIntro.eyebrow}</p>
        <h2 class="pm-section-title text-left rtl:text-right">
          {copy.collaborationIntro.heading}{' '}
          <span class="pm-gradient-text">{copy.collaborationIntro.headingAccent}</span>
        </h2>
        <p class="pm-section-sub text-left rtl:text-right">{copy.collaborationIntro.subtext}</p>
        <div class="space-y-4 pt-2">
          {
            copy.collaborationItems.map((item, i) => (
              <div class="pm-card pm-card--horizontal">
                <IconBadge icon={item.icon} color={i % 2 === 0 ? 'gold' : 'sage'} />
                <div class="min-w-0 flex-1">
                  <h3 class="pm-card-title">{item.title}</h3>
                  <p class="pm-card-desc">{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <div class="order-1 lg:order-2" data-pm-reveal data-pm-reveal-once>
        <div class="overflow-hidden rounded-2xl border border-[color:var(--pm-border)] bg-[color:var(--pm-surface)] p-3 shadow-lg">
          <img
            src="/images/global-collaboration.webp"
            alt={copy.collaborationImageAlt}
            class="h-auto w-full rounded-xl object-cover"
            width="800"
            height="600"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<section class="pm-section pm-section--mesh pm-section--sep">
  <div class="pm-container">
    <header class="pm-section-header" data-pm-reveal data-pm-reveal-once>
      <h2 class="pm-section-title">
        {copy.valuesIntro.heading ? `${copy.valuesIntro.heading} ` : ''}
        <span class="pm-gradient-text">{copy.valuesIntro.headingAccent}</span>
      </h2>
      <p class="pm-section-sub">{copy.valuesIntro.subtext}</p>
    </header>

    <div class="pm-grid pm-grid--4">
      {
        copy.valuesCards.map((item, i) => (
          <div data-pm-reveal data-pm-reveal-once>
            <PmCard
              icon={item.icon}
              iconColor={i % 2 === 0 ? 'gold' : 'sage'}
              title={item.title}
              description={item.description}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<section class="pm-section pm-section--mesh pm-section--sep pb-20 md:pb-24">
  <div class="pm-container">
    <div class="pm-split">
      <div class="order-1 lg:order-1" data-pm-reveal data-pm-reveal-once>
        <div class="overflow-hidden rounded-2xl border border-[color:var(--pm-border)] bg-[color:var(--pm-surface)] p-3 shadow-lg">
          <img
            src="/images/professional-development.webp"
            alt={copy.devImageAlt}
            class="h-auto w-full rounded-xl object-cover"
            width="800"
            height="600"
            loading="lazy"
          />
        </div>
      </div>
      <div class="order-2 space-y-6 lg:order-2" data-pm-reveal data-pm-reveal-once>
        <p class="pm-eyebrow">{copy.devIntro.eyebrow}</p>
        <h2 class="pm-section-title text-left rtl:text-right">
          {copy.devIntro.heading}{' '}
          <span class="pm-gradient-text">{copy.devIntro.headingAccent}</span>
        </h2>
        <p class="pm-section-sub text-left rtl:text-right">{copy.devIntro.subtext}</p>
        <div class="grid gap-6">
          {
            copy.devCards.map((item, i) => (
              <div class="pm-card pm-card--horizontal">
                <IconBadge icon={item.icon} color={i % 2 === 0 ? 'gold' : 'sage'} />
                <div class="min-w-0 flex-1">
                  <h3 class="pm-card-title">{item.title}</h3>
                  <p class="pm-card-desc">{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
