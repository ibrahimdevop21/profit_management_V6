---
import { getLangFromUrl, useTranslations, localizePath } from '~/utils/i18n';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const url = new URL(Astro.request.url);
const currentLang = getLangFromUrl(url);
const t = useTranslations(currentLang);

const navItems = [
  { key: 'nav.home', en: '/', ar: '/ar' },
  { key: 'nav.about', en: '/about', ar: '/ar/about' },
  { key: 'nav.services', en: '/services', ar: '/ar/services' },
  { key: 'nav.industries', en: '/industries', ar: '/ar/industries' },
  { key: 'nav.why', en: '/why', ar: '/ar/why' },
  { key: 'nav.contact', en: '/contact', ar: '/ar/contact' },
] as const;

---

<div id="mobile-menu" class="pm-mobile-menu" aria-hidden="true">
  <div class="pm-mobile-menu-inner">
    <ul class="pm-mobile-menu-list" aria-label="Mobile navigation">
      {
        navItems.map((item) => {
          const href = currentLang === 'ar' ? item.ar : currentLang === 'fr' ? localizePath(item.en, 'fr') : item.en;
          const isActive = currentPath === href;
          return (
            <li>
              <a href={href} class={`pm-mobile-link ${isActive ? 'is-active' : ''}`}>
                {t(item.key)}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</div>

<style>
  .pm-mobile-menu {
    position: fixed;
    top: var(--pm-header-offset);
    left: 0;
    right: 0;
    z-index: 998;
    background: #0d0f14;
    border-top: 1px solid var(--pm-border);
    border-bottom: 1px solid var(--pm-border);
    transform-origin: top;
    transform: scaleY(0);
    opacity: 0;
    pointer-events: none;
    transition: transform 220ms ease, opacity 220ms ease;
  }

  .pm-mobile-menu.show {
    transform: scaleY(1);
    opacity: 1;
    pointer-events: auto;
  }

  .pm-mobile-menu-inner {
    padding: 0.75rem 1.25rem 1.1rem;
  }

  .pm-mobile-menu-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pm-mobile-link {
    min-height: 48px;
    display: flex;
    align-items: center;
    padding: 0.75rem 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--pm-font-body);
    font-size: 0.85rem;
    color: #a8a8a8;
    text-decoration: none;
    border-radius: 0.5rem;
    transition: color 200ms ease, background-color 200ms ease;
  }

  .pm-mobile-link:hover,
  .pm-mobile-link.is-active {
    color: #c9a84c;
    background: rgba(255, 255, 255, 0.03);
  }

  @media (min-width: 768px) {
    .pm-mobile-menu {
      display: none;
    }
  }
</style>

<script>
  /** Abort previous listeners when setup runs again (DOMContentLoaded + astro:page-load). */
  let mobileNavAbort: AbortController | null = null;

  function setupMobileNav() {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    if (!button || !menu) return;

    mobileNavAbort?.abort();
    mobileNavAbort = new AbortController();
    const { signal } = mobileNavAbort;

    const closeMenu = () => {
      menu.classList.remove('show');
      button.classList.remove('hamburger-active');
      button.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    };

    const toggleMenu = (event: Event) => {
      event.preventDefault();
      event.stopPropagation();
      const open = menu.classList.contains('show');
      if (open) {
        closeMenu();
        return;
      }
      menu.classList.add('show');
      button.classList.add('hamburger-active');
      button.setAttribute('aria-expanded', 'true');
      menu.setAttribute('aria-hidden', 'false');
    };

    button.addEventListener('click', toggleMenu, { signal });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => closeMenu(), { signal });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenu();
    }, { signal });

    window.addEventListener(
      'resize',
      () => {
        if (window.innerWidth >= 768) closeMenu();
      },
      { signal }
    );

    document.addEventListener(
      'click',
      (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (menu.contains(target) || button.contains(target)) return;
        closeMenu();
      },
      { signal }
    );
  }

  document.addEventListener('DOMContentLoaded', setupMobileNav);
  document.addEventListener('astro:page-load', setupMobileNav);
  if (document.readyState !== 'loading') setupMobileNav();
</script>
