---
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations, localizePath } from '~/utils/i18n';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

export interface Props {
  socialLinks: Array<Link>;
  footNote?: string;
}

const { socialLinks = [], footNote = '' } = Astro.props;
const currentLang = getLangFromUrl(new URL(Astro.request.url));
const t = useTranslations(currentLang);
const year = new Date().getFullYear();
const resolvedFootNote =
  footNote.trim() !== '' ? footNote : t('footer.copyright').replaceAll('{year}', String(year));

const localizeHref = (href: string) => {
  if (!href.startsWith('/')) return href;
  if (href.startsWith('/legal/')) return href;
  const [path, hash = ''] = href.split('#');
  const localized = localizePath(path || '/', currentLang);
  return hash ? `${localized}#${hash}` : localized;
};

const servicesLinks = [
  { key: 'footer.allServices', href: '/services' },
  { key: 'footer.corpProfitGrowth', href: '/services#profit-growth' },
  { key: 'footer.businessTransformation', href: '/services#transformation' },
  { key: 'footer.strategicSupport', href: '/services#strategic-support' },
  { key: 'footer.trainingDev', href: '/services#training' },
];

const companyLinks = [
  { key: 'footer.aboutUs', href: '/about' },
  { key: 'footer.ourTeam', href: '/team' },
  { key: 'footer.industriesServed', href: '/industries' },
  { key: 'footer.whyChooseUs', href: '/why' },
];

const supportLinks = [
  { key: 'footer.contactUs', href: '/contact' },
  { key: 'footer.bookConsultation', href: '/contact' },
  { key: 'footer.trainingPrograms', href: '/services#training' },
];

const legalLinks = [
  { key: 'footer.privacy', href: '/legal/privacy' },
  { key: 'footer.terms', href: '/legal/terms' },
];
---

<footer class="pm-footer not-prose">
  <div class="pm-container">
    <div class="pm-footer-grid">
      <div class="pm-footer-brand">
        <a class="inline-block" href={localizePath('/', currentLang)}>
          <img
            src="/profit.png"
            alt="Profit Management Consulting & Training"
            class="h-10 w-auto"
            loading="lazy"
            width={200}
            height={40}
          />
        </a>

        <p class="pm-footer-tagline">{t('footer.description')}</p>

        <ul class="pm-footer-social-row">
          {
            socialLinks.map(({ ariaLabel, href, icon }) => (
              <li>
                <a aria-label={ariaLabel} href={href} class="pm-social-circle">
                  {icon && <Icon name={icon} class="h-4 w-4" />}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="pm-footer-links-col">
        <h3 class="pm-footer-heading">{t('footer.services')}</h3>
        <ul class="pm-footer-links-list">
          {servicesLinks.map(({ key, href }) => <li><a href={localizeHref(href)}>{t(key)}</a></li>)}
        </ul>
      </div>

      <div class="pm-footer-links-col">
        <h3 class="pm-footer-heading">{t('footer.company')}</h3>
        <ul class="pm-footer-links-list">
          {companyLinks.map(({ key, href }) => <li><a href={localizeHref(href)}>{t(key)}</a></li>)}
        </ul>
      </div>

      <div class="pm-footer-links-col pm-footer-links-col--stacked">
        <div>
          <h3 class="pm-footer-heading">{t('footer.support')}</h3>
          <ul class="pm-footer-links-list">
            {supportLinks.map(({ key, href }) => <li><a href={localizeHref(href)}>{t(key)}</a></li>)}
          </ul>
        </div>

        <div>
          <h3 class="pm-footer-heading">{t('footer.legal')}</h3>
          <ul class="pm-footer-links-list">
            {legalLinks.map(({ key, href }) => <li><a href={href}>{t(key)}</a></li>)}
          </ul>
        </div>
      </div>
    </div>

    <div class="pm-footer-bottom">
      <div class="pm-footer-copyright">
        <Fragment set:html={resolvedFootNote} />
      </div>

      <ul class="pm-footer-social-bottom">
        {
          socialLinks.map(({ ariaLabel, href, icon }) => (
            <li>
              <a aria-label={ariaLabel} href={href} class="pm-social-circle pm-social-circle--small">
                {icon && <Icon name={icon} class="h-4 w-4" />}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>

<style>
  .pm-footer {
    background: #080d18;
    border-top: 1px solid rgba(201, 168, 76, 0.2);
    padding: 4rem 0 2rem;
  }

  .pm-footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 2rem;
  }

  .pm-footer-brand {
    padding-right: 1rem;
  }

  .pm-footer-tagline {
    margin-top: 0.85rem;
    margin-bottom: 1rem;
    color: #a8a8a8;
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .pm-footer-social-row,
  .pm-footer-social-bottom {
    display: flex;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pm-social-circle {
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(201, 168, 76, 0.25);
    color: #a8a8a8;
    background: transparent;
    transition: color 200ms ease, background-color 200ms ease, border-color 200ms ease;
  }

  .pm-social-circle:hover {
    color: #c9a84c;
    background: rgba(201, 168, 76, 0.1);
    border-color: rgba(201, 168, 76, 0.45);
  }

  .pm-social-circle--small {
    width: 34px;
    height: 34px;
  }

  .pm-footer-heading {
    margin: 0 0 0.75rem;
    font-family: var(--pm-font-body);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.7rem;
    color: #c9a84c;
  }

  .pm-footer-links-col--stacked {
    display: grid;
    gap: 1.35rem;
  }

  .pm-footer-links-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.45rem;
  }

  .pm-footer-links-list a {
    color: #a8a8a8;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 200ms ease;
  }

  .pm-footer-links-list a:hover {
    color: #c9a84c;
  }

  .pm-footer-bottom {
    margin-top: 2.4rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(201, 168, 76, 0.2);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .pm-footer-copyright {
    font-size: 0.8rem;
    color: #666;
  }

  @media (max-width: 1023px) {
    .pm-footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.6rem;
    }

    .pm-footer-brand {
      grid-column: 1 / -1;
      padding-right: 0;
    }
  }

  @media (max-width: 767px) {
    .pm-footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  [dir='rtl'] .pm-footer-bottom {
    flex-direction: row-reverse;
  }
</style>
