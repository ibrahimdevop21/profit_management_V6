---
import MobileNavigation from '~/components/MobileNavigation.astro';
import { getLangFromUrl, useTranslations, localizePath, languages } from '~/utils/i18n';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const url = new URL(Astro.request.url);
const currentLang = getLangFromUrl(url);
const t = useTranslations(currentLang);

const navItems = [
  { key: 'nav.home', en: '/', ar: '/ar' },
  { key: 'nav.about', en: '/about', ar: '/ar/about' },
  { key: 'nav.services', en: '/services', ar: '/ar/services' },
  { key: 'nav.industries', en: '/industries', ar: '/ar/industries' },
  { key: 'nav.why', en: '/why', ar: '/ar/why' },
  { key: 'nav.contact', en: '/contact', ar: '/ar/contact' },
] as const;

const localeOptions = [
  { code: 'en', label: 'EN' },
  { code: 'ar', label: 'AR' },
  { code: 'fr', label: 'FR' },
] as const;

---

<header id="header" data-aw-sticky-header class="pm-site-header">
  <nav class="pm-container">
    <div class="pm-nav-row">
      <a href={localizePath('/', currentLang)} class="pm-brand" aria-label="Profit Management home">
        <img src="/profit.png" alt="Profit Management Logo" class="h-8 w-auto" />
      </a>

      <ul class="pm-desktop-nav" aria-label="Primary navigation">
        {
          navItems.map((item) => {
            const href = currentLang === 'ar' ? item.ar : currentLang === 'fr' ? localizePath(item.en, 'fr') : item.en;
            const isActive = currentPath === href;
            return (
              <li>
                <a href={href} class={`pm-nav-link ${isActive ? 'is-active' : ''}`}>
                  {t(item.key)}
                </a>
              </li>
            );
          })
        }
      </ul>

      <div class="pm-nav-actions">

        <div class="pm-lang-switch" role="group" aria-label={t('lang.switch')}>
          {
            localeOptions.map((option) => {
              const active = currentLang === option.code;
              return (
                <a
                  href={localizePath(currentPath, option.code)}
                  class:list={['pm-lang-seg', active && 'is-active']}
                  aria-current={active ? 'true' : undefined}
                  title={languages[option.code]}
                  lang={option.code}
                >
                  <span class="pm-lang-seg__label">{option.label}</span>
                </a>
              );
            })
          }
        </div>

        <button
          type="button"
          class="pm-hamburger md:hidden"
          aria-controls="mobile-menu"
          aria-expanded="false"
          id="mobile-menu-button"
        >
          <span class="sr-only">{t('nav.openMenu')}</span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
    </div>
  </nav>
</header>

<MobileNavigation currentPath={currentPath} />

<style>
  .pm-nav-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    min-height: var(--pm-header-offset);
  }

  .pm-brand {
    display: inline-flex;
    align-items: center;
  }

  .pm-desktop-nav {
    display: none;
  }

  .pm-nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: end;
  }

  .pm-hamburger {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    border: 1px solid var(--pm-border);
    border-radius: 10px;
    background: transparent;
    color: var(--pm-text-heading);
    transition: border-color 200ms ease, color 200ms ease, background-color 200ms ease;
  }

  .pm-hamburger:hover {
    color: var(--pm-accent);
    border-color: var(--pm-border-strong);
    background: rgba(255, 255, 255, 0.03);
  }

  .hamburger-line {
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
    transition: transform 200ms ease, opacity 200ms ease;
  }

  .pm-hamburger.hamburger-active .hamburger-line:nth-child(2) {
    transform: translateY(7px) rotate(45deg);
  }

  .pm-hamburger.hamburger-active .hamburger-line:nth-child(3) {
    opacity: 0;
  }

  .pm-hamburger.hamburger-active .hamburger-line:nth-child(4) {
    transform: translateY(-7px) rotate(-45deg);
  }


  .pm-lang-switch {
    display: inline-flex;
    align-items: stretch;
    flex-shrink: 0;
    padding: 3px;
    border-radius: 12px;
    border: 1px solid var(--pm-border);
    background: rgba(255, 255, 255, 0.04);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .pm-lang-seg {
    position: relative;
    z-index: 0;
    min-width: 2.75rem;
    min-height: 44px;
    padding: 0 0.55rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #8a8f9a;
    text-decoration: none;
    transition: color 180ms ease, background-color 180ms ease, box-shadow 180ms ease;
  }

  .pm-lang-seg:hover {
    color: #e8e4dc;
  }

  .pm-lang-seg:focus-visible {
    outline: 2px solid rgba(201, 168, 76, 0.65);
    outline-offset: 2px;
    z-index: 1;
  }

  .pm-lang-seg.is-active {
    z-index: 1;
    color: #0d0f14;
    background: linear-gradient(165deg, #d4b45a 0%, #c9a84c 55%, #b8943a 100%);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }

  .pm-lang-seg__label {
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .pm-desktop-nav {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.7rem;
    }

    .pm-nav-link {
      font-family: var(--pm-font-body);
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      white-space: nowrap;
      color: #a8a8a8;
      text-decoration: none;
      transition: color 200ms ease;
      display: inline-flex;
      min-height: 44px;
      align-items: center;
      padding: 0 0.35rem;
    }

    .pm-nav-link:hover,
    .pm-nav-link.is-active {
      color: #c9a84c;
    }

    .pm-lang-seg {
      min-height: 36px;
      min-width: 3rem;
      padding: 0 0.65rem;
      font-size: 0.72rem;
    }

    .pm-hamburger {
      display: none;
    }
  }
</style>
