---
import merge from 'lodash.merge';
import { AstroSeo } from '@astrolib/seo';

import type { Props as AstroSeoProps } from '@astrolib/seo';

import { SITE, METADATA } from '~/config';
import type { MetaData } from '~/types';
import { getCanonical } from '~/utils/permalinks';
import { getLangFromUrl, stripLocalePrefix } from '~/utils/i18n';
// Using Profit Management logo from public folder
const defaultOgImageUrl = '/profit.png';

export interface Props extends MetaData {
  dontUseTitleTemplate?: boolean;
}

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  robots = {},
  description,
  openGraph = {},
  twitter = {},
} = Astro.props;

const currentLang = getLangFromUrl(Astro.url);
const normalizedPath = stripLocalePrefix(Astro.url.pathname).replace(/\/+$/, '') || '/';

const PAGE_NAME_BY_PATH: Record<string, { en: string; ar: string; fr: string }> = {
  '/': { en: '', ar: '', fr: '' },
  '/about': { en: 'About Us', ar: 'عن الشركة', fr: 'À Propos' },
  '/services': { en: 'Services', ar: 'خدماتنا', fr: 'Services' },
  '/industries': { en: 'Industries', ar: 'القطاعات', fr: 'Secteurs' },
  '/why': { en: 'Why Choose Us', ar: 'لماذا نحن', fr: 'Pourquoi Nous' },
  '/team': { en: 'Our Team', ar: 'فريقنا', fr: 'Notre Équipe' },
  '/contact': { en: 'Contact Us', ar: 'تواصل معنا', fr: 'Contact' },
  '/faq': { en: 'FAQ', ar: 'الأسئلة الشائعة', fr: 'FAQ' },
  '/legal/privacy': { en: 'Privacy Policy', ar: 'سياسة الخصوصية', fr: 'Politique de Confidentialité' },
  '/legal/terms': { en: 'Terms of Service', ar: 'الشروط والأحكام', fr: "Conditions d'Utilisation" },
  '/privacy': { en: 'Privacy Policy', ar: 'سياسة الخصوصية', fr: 'Politique de Confidentialité' },
  '/terms': { en: 'Terms of Service', ar: 'الشروط والأحكام', fr: "Conditions d'Utilisation" },
  '/404': { en: 'Page Not Found', ar: 'الصفحة غير موجودة', fr: 'Page Introuvable' },
};

const localizedPageName = PAGE_NAME_BY_PATH[normalizedPath]?.[currentLang] ?? '';
const computedShortTitle =
  normalizedPath === '/'
    ? 'Profit Management Consulting & Training'
    : localizedPageName
      ? `${localizedPageName} | Profit Management`
      : 'Profit Management';

/** Prefer explicit title from page metadata (e.g. createMetadata); otherwise localized path-based title. */
const seoTitle = typeof title === 'string' && title.trim() !== '' ? title.trim() : computedShortTitle;

const pageDescription = description ?? METADATA?.description;
const ogLocale = currentLang === 'fr' ? 'fr_FR' : currentLang === 'ar' ? 'ar_EG' : 'en_US';

// Process OpenGraph images - use default Profit Management logo or custom images if provided
const processedOpenGraphImages = openGraph?.images?.length 
  ? openGraph.images 
  : [{
      url: defaultOgImageUrl,
      width: 1200,
      height: 630,
      alt: 'Profit Management Consulting & Training | Profit as Precision',
    }];

const seoProps: AstroSeoProps = merge(
  {
    title: '',
    titleTemplate: '%s',
    canonical: canonical,
    noindex: true,
    nofollow: true,
    description: undefined,
    openGraph: {
      url: canonical,
      site_name: SITE?.name,
      images: processedOpenGraphImages,
      locale: 'en',
      type: 'website',
    },
    twitter: {
      cardType: 'summary_large_image',
    },
  },
  {
    title: computedShortTitle || METADATA?.title?.default,
    titleTemplate: METADATA?.title?.template,
    noindex: typeof METADATA?.robots?.index !== 'undefined' ? !METADATA.robots.index : undefined,
    nofollow: typeof METADATA?.robots?.follow !== 'undefined' ? !METADATA.robots.follow : undefined,
    description: METADATA?.description,
    openGraph: {
      ...METADATA?.openGraph,
      description: METADATA?.openGraph?.description ?? METADATA?.description,
      images: processedOpenGraphImages, // Always use processed images
    },
    twitter: {
      ...METADATA?.twitter,
      cardType: 'summary_large_image', // Always use large image card
    },
  },
  {
    title: seoTitle,
    titleTemplate: '%s',
    canonical: canonical,
    noindex: typeof robots?.index !== 'undefined' ? !robots.index : undefined,
    nofollow: typeof robots?.follow !== 'undefined' ? !robots.follow : undefined,
    description: pageDescription,
    openGraph: {
      title: seoTitle,
      url: canonical,
      description: pageDescription,
      locale: ogLocale,
      ...openGraph,
      images: openGraph?.images?.length ? openGraph.images : processedOpenGraphImages,
    },
    twitter: {
      ...twitter,
      description: pageDescription,
      cardType: 'summary_large_image', // Ensure Twitter always uses large image
    },
  }
);
---

<AstroSeo {...seoProps} />
