---
import { getAsset } from '~/utils/permalinks';
import { stripLocalePrefix, localizePath } from '~/utils/i18n';

const basePath = stripLocalePrefix(Astro.url.pathname);
const canonicalBase = Astro.site ? new URL(Astro.site) : new URL(Astro.url.origin);
const enHref = new URL(localizePath(basePath, 'en'), canonicalBase).toString();
const arHref = new URL(localizePath(basePath, 'ar'), canonicalBase).toString();
const frHref = new URL(localizePath(basePath, 'fr'), canonicalBase).toString();
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- Preconnect to external domains for better performance -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<!-- Typography: Playfair Display (headings), DM Sans (UI/body), DM Mono (numerals) -->
<link
  href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=DM+Sans:ital,opsz,wght@0,9..40,400..700;1,9..40,400..700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
  rel="stylesheet"
  media="print"
  onload="this.media='all'"
/>
<link
  href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap"
  rel="stylesheet"
  media="print"
  onload="this.media='all'"
/>
<noscript>
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=DM+Sans:ital,opsz,wght@0,9..40,400..700;1,9..40,400..700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
    rel="stylesheet"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</noscript>

<link rel="alternate" hreflang="en" href={enHref} />
<link rel="alternate" hreflang="ar" href={arHref} />
<link rel="alternate" hreflang="fr" href={frHref} />
<link rel="alternate" hreflang="x-default" href={enHref} />

<link rel="sitemap" href={getAsset('/sitemap-index.xml')} />
