---
import PageLayout from '~/layouts/PageLayout.astro';
import ServicesPage from '~/components/pages/ServicesPage.astro';
import { createMetadata } from '~/utils/metadata';
import { getLangFromUrl, useTranslations, defaultLang } from '~/utils/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const canonical = lang === defaultLang ? '/services' : `/${lang}/services`;
const metadata = createMetadata({
  description: t('meta.services.description'),
  canonical,
});
---

<PageLayout metadata={metadata}>
  <ServicesPage />
</PageLayout>
