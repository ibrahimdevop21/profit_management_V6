---
import PageLayout from '~/layouts/PageLayout.astro';
import IndustriesPageMain from '~/components/pages/IndustriesPageMain.astro';
import { createMetadata } from '~/utils/metadata';
import { getLangFromUrl, defaultLang } from '~/utils/i18n';

const lang = getLangFromUrl(Astro.url);
const canonical = lang === defaultLang ? '/industries' : `/${lang}/industries`;
const metadata = createMetadata({
  title: 'القطاعات الصناعية',
  description:
    'خبرة واسعة عبر أكثر من 60 قطاعاً صناعياً. من الصناعات الطبية إلى التصنيع والعقارات، نقدم حلول ربحية مخصصة لكل قطاع.',
  canonical,
});
---

<PageLayout metadata={metadata}>
  <IndustriesPageMain />
</PageLayout>
