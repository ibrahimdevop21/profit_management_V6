---
import Layout from '~/layouts/PageLayout.astro';
import PageHero from '~/components/widgets/PageHero.astro';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations } from '~/utils/i18n';
import { createMetadata } from '~/utils/metadata';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pageHeroLang = lang === 'fr' ? 'fr' : lang === 'ar' ? 'ar' : 'en';

const metadata = createMetadata({
  title: 'Terms of Service',
  description:
    'Profit Management terms and conditions for consulting, training, and professional services.',
  canonical: '/legal/terms',
});
---

<Layout metadata={metadata}>
  <PageHero
    lang={pageHeroLang}
    heroImage="/5.avif"
    eyebrow={t('pageHero.terms.eyebrow')}
    heading={t('pageHero.terms.heading')}
    headingAccent={t('pageHero.terms.headingAccent')}
    subtext={t('pageHero.terms.subtext')}
  />

  <section class="pm-section pm-section--mesh pm-section--sep pb-20 md:pb-24">
    <div class="pm-container max-w-3xl">
      <div
        class="mb-12 rounded-2xl border border-[color:var(--pm-border)] bg-[color:var(--pm-surface-elevated)] p-6"
      >
        <div class="mb-2 flex items-center gap-3">
          <Icon name="tabler:calendar" class="h-5 w-5 text-[color:var(--pm-accent)]" />
          <span class="font-heading text-sm font-semibold tracking-wide text-[color:var(--pm-text-heading)]"
            >Last Updated</span
          >
        </div>
        <p class="font-body text-[color:var(--pm-text-body)]">October 28, 2025</p>
      </div>

      <div class="pm-legal-doc max-w-none">
        
        <!-- Acceptance of Terms -->
        <section class="mb-12">
          <h2 class="mb-6 flex items-center gap-3 font-heading text-2xl font-bold text-[color:var(--pm-text-heading)]">
            <Icon name="tabler:check" class="h-6 w-6 text-[color:var(--pm-accent)]" />
            Acceptance of Terms
          </h2>
          <div class="space-y-4 font-body text-[color:var(--pm-text-body)]">
            <p class="leading-relaxed">
              By engaging our consulting and training services, you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our services.
            </p>
            <p class="leading-relaxed">
              These terms apply to all clients, whether individuals or organizations, who engage Profit Management Consulting & Training for any of our professional services.
            </p>
          </div>
        </section>

        <!-- Services Description -->
        <section class="mb-12">
          <h2 class="mb-6 flex items-center gap-3 font-heading text-2xl font-bold text-[color:var(--pm-text-heading)]">
            <Icon name="tabler:briefcase" class="h-6 w-6 text-[color:var(--pm-accent)]" />
            Services Description
          </h2>
          <div class="space-y-4 font-body text-[color:var(--pm-text-body)]">
            <p class="leading-relaxed">
              Profit Management Consulting & Training provides professional consulting and training services including:
            </p>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Corporate profit growth consulting</li>
              <li>Business transformation services</li>
              <li>Strategic decision support</li>
              <li>Training and development programs</li>
              <li>ERP integration and digital transformation</li>
              <li>Financial analysis and cost management</li>
            </ul>
          </div>
        </section>

        <!-- Client Responsibilities -->
        <section class="mb-12">
          <h2 class="mb-6 flex items-center gap-3 font-heading text-2xl font-bold text-[color:var(--pm-text-heading)]">
            <Icon name="tabler:user" class="h-6 w-6 text-[color:var(--pm-accent)]" />
            Client Responsibilities
          </h2>
          <div class="space-y-4 font-body text-[color:var(--pm-text-body)]">
            <p class="leading-relaxed">
              Clients agree to:
            </p>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Provide accurate and complete information necessary for service delivery</li>
              <li>Grant reasonable access to personnel, systems, and data as required</li>
              <li>Participate actively in the consulting process</li>
              <li>Make timely payments according to agreed terms</li>
              <li>Maintain confidentiality of proprietary methodologies</li>
              <li>Implement recommendations in good faith</li>
            </ul>
          </div>
        </section>

        <!-- Payment Terms -->
        <section class="mb-12">
          <h2 class="mb-6 flex items-center gap-3 font-heading text-2xl font-bold text-[color:var(--pm-text-heading)]">
            <Icon name="tabler:coins" class="h-6 w-6 text-[color:var(--pm-accent)]" />
            Payment Terms
          </h2>
          <div class="space-y-4 font-body text-[color:var(--pm-text-body)]">
            <p class="leading-relaxed">
              Payment terms are specified in individual service agreements. Generally:
            </p>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Consulting fees are payable according to agreed milestones</li>
              <li>Training program fees are typically due before program commencement</li>
              <li>Late payments may incur additional charges</li>
              <li>Disputed charges must be raised within 30 days of invoice</li>
              <li>All fees are exclusive of applicable taxes</li>
            </ul>
          </div>
        </section>

        <!-- Confidentiality -->
        <section class="mb-12">
          <h2 class="mb-6 flex items-center gap-3 font-heading text-2xl font-bold text-[color:var(--pm-text-heading)]">
            <Icon name="tabler:shield" class="h-6 w-6 text-[color:var(--pm-accent)]" />
            Confidentiality
          </h2>
          <div class="space-y-4 font-body text-[color:var(--pm-text-body)]">
            <p class="leading-relaxed">
              We maintain strict confidentiality regarding all client information:
            </p>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>All client data and business information is kept confidential</li>
              <li>Information is only shared with authorized team members</li>
              <li>Client consent is required before using case studies or testimonials</li>
              <li>Confidentiality obligations survive termination of services</li>
              <li>We may be required to disclose information if legally compelled</li>
            </ul>
          </div>
        </section>

        <!-- Intellectual Property -->
        <section class="mb-12">
          <h2 class="mb-6 flex items-center gap-3 font-heading text-2xl font-bold text-[color:var(--pm-text-heading)]">
            <Icon name="tabler:copyright" class="h-6 w-6 text-[color:var(--pm-accent)]" />
            Intellectual Property
          </h2>
          <div class="space-y-4 font-body text-[color:var(--pm-text-body)]">
            <p class="leading-relaxed">
              Intellectual property rights are allocated as follows:
            </p>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Our methodologies and frameworks remain our intellectual property</li>
              <li>Client-specific deliverables become client property upon full payment</li>
              <li>We retain rights to general knowledge and experience gained</li>
              <li>Clients may not reproduce or distribute our proprietary materials</li>
              <li>Joint developments are subject to separate agreement</li>
            </ul>
          </div>
        </section>

        <!-- Limitation of Liability -->
        <section class="mb-12">
          <h2 class="mb-6 flex items-center gap-3 font-heading text-2xl font-bold text-[color:var(--pm-text-heading)]">
            <Icon name="tabler:scale" class="h-6 w-6 text-[color:var(--pm-accent)]" />
            Limitation of Liability
          </h2>
          <div class="space-y-4 font-body text-[color:var(--pm-text-body)]">
            <p class="leading-relaxed">
              Our liability is limited as follows:
            </p>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Total liability shall not exceed fees paid for the specific engagement</li>
              <li>We are not liable for indirect, consequential, or punitive damages</li>
              <li>Client implementation decisions are at client's own risk</li>
              <li>Results depend on client execution and market conditions</li>
              <li>We provide professional opinions, not guarantees of specific outcomes</li>
            </ul>
          </div>
        </section>

        <!-- Termination -->
        <section class="mb-12">
          <h2 class="mb-6 flex items-center gap-3 font-heading text-2xl font-bold text-[color:var(--pm-text-heading)]">
            <Icon name="tabler:x" class="h-6 w-6 text-[color:var(--pm-accent)]" />
            Termination
          </h2>
          <div class="space-y-4 font-body text-[color:var(--pm-text-body)]">
            <p class="leading-relaxed">
              Either party may terminate services under the following conditions:
            </p>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>30 days written notice for ongoing consulting engagements</li>
              <li>Immediate termination for material breach of contract</li>
              <li>Payment for work completed up to termination date</li>
              <li>Return of confidential materials upon termination</li>
              <li>Survival of confidentiality and payment obligations</li>
            </ul>
          </div>
        </section>

        <!-- Governing Law -->
        <section class="mb-12">
          <h2 class="mb-6 flex items-center gap-3 font-heading text-2xl font-bold text-[color:var(--pm-text-heading)]">
            <Icon name="tabler:scale" class="h-6 w-6 text-[color:var(--pm-accent)]" />
            Governing Law
          </h2>
          <div class="space-y-4 font-body text-[color:var(--pm-text-body)]">
            <p class="leading-relaxed">
              These terms are governed by the laws of Egypt. Any disputes shall be resolved through:
            </p>
            <ul class="list-disc list-inside ml-4 space-y-2">
              <li>Good faith negotiation as the first step</li>
              <li>Mediation if negotiation fails</li>
              <li>Arbitration or court proceedings as a last resort</li>
              <li>Egyptian courts have jurisdiction over disputes</li>
            </ul>
          </div>
        </section>

        <!-- Contact Information -->
        <section class="mb-12">
          <h2 class="mb-6 flex items-center gap-3 font-heading text-2xl font-bold text-[color:var(--pm-text-heading)]">
            <Icon name="tabler:mail" class="h-6 w-6 text-[color:var(--pm-accent)]" />
            Contact Information
          </h2>
          <div class="space-y-4 font-body text-[color:var(--pm-text-body)]">
            <p class="leading-relaxed">
              For questions about these Terms of Service, please contact us:
            </p>
            <div
              class="rounded-xl border border-[color:var(--pm-border)] bg-[color:var(--pm-surface-elevated)] p-6"
            >
              <p class="font-semibold text-[color:var(--pm-text-heading)]">Profit Management Consulting & Training</p>
              <p>Email: info@profit-manage.com</p>
              <p>Location: Cairo, Egypt</p>
            </div>
          </div>
        </section>

        <!-- Changes to Terms -->
        <section class="mb-12">
          <h2 class="mb-6 flex items-center gap-3 font-heading text-2xl font-bold text-[color:var(--pm-text-heading)]">
            <Icon name="tabler:refresh" class="h-6 w-6 text-[color:var(--pm-accent)]" />
            Changes to Terms
          </h2>
          <div class="space-y-4 font-body text-[color:var(--pm-text-body)]">
            <p class="leading-relaxed">
              We reserve the right to modify these terms at any time. Material changes will be communicated to existing clients. Continued use of our services after changes constitutes acceptance of the updated terms.
            </p>
          </div>
        </section>

      </div>
    </div>
  </section>
</Layout>
